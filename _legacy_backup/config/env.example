# Configuración de Variables de Entorno
# Copiar este archivo a .env y completar los valores

# ============================================
# SUPABASE
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# ============================================
# GOOGLE CLOUD PLATFORM
# ============================================
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
GOOGLE_VISION_API_KEY=your-vision-api-key

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ============================================
# EMAIL/SMTP (para reportes)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_TO=reports@yourdomain.com

# ============================================
# N8N CONFIGURATION
# ============================================
N8N_HOST=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key

# ============================================
# BUBBLE/FLUTTERFLOW
# ============================================
# Configuración para el frontend
APP_NAME=SaaS Financiero Audiovisual
APP_VERSION=1.0.0

# ============================================
# WEBHOOKS
# ============================================
WEBHOOK_PROCESS_INVOICE=/webhook/process-invoice
WEBHOOK_MARK_PAID=/webhook/mark-paid

# ============================================
# BUSINESS RULES
# ============================================
# Días de gracia para alertas de renta
RENTAL_GRACE_DAYS=1
# Días para considerar pago como pendiente
PAYMENT_OVERDUE_DAYS=30
# Moneda por defecto (MXN, USD)
DEFAULT_CURRENCY=MXN

# ============================================
# DEPRECIACIÓN DE EQUIPO
# ============================================
# Vida útil predeterminada en meses (5 años)
DEFAULT_USEFUL_LIFE_MONTHS=60
# Porcentaje mínimo de valor para depreciación
MIN_DEPRECIATION_VALUE=0.01
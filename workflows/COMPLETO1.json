      "parameters": {
        "functionCode": "// Procesar equipos que vencen mañana\nconst data = $input.first().json;\nconst equipment = data.equipment;\n\nif (equipment.length === 0) {\n  return [{ json: { alerts_created: 0 } }];\n}\n\nconst alerts = [];\nfor (const item of equipment) {\n  alerts.push({\n    user_id: item.user_id,\n    tipo_alerta: 'renta_vence_manana',\n    referencia_id: item.id,\n    fecha_ejecucion: new Date().toISOString().split('T')[0],\n    message: `⚠️ El ${item.nombre} rentado de ${item.proveedor_renta} vence mañana ${item.fecha_fin_renta}. ¿Ya lo devolviste?`\n  });\n}\n\nreturn alerts.map(alert => ({ json: alert }));"

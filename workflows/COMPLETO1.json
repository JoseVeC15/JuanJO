        1216
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.type }}",
        "rules": {
          "rules": [
            {
              "value2": "tomorrow"
            },
            {
              "value2": "today",
              "output": 1
            }
          ]
        }

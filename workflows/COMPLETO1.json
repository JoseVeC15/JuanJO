      "parameters": {
        "functionCode": "// Preparar resumen para notificación\nlet tomorrowCount = 0;\nlet todayCount = 0;\n\ntry {\n  const tomorrowAlerts = $node[\"Insertar Alertas Mañana\"];\n  if (tomorrowAlerts && tomorrowAlerts.json) {\n    tomorrowCount = Array.isArray(tomorrowAlerts.json) ? tomorrowAlerts.json.length : 1;\n  }\n} catch (e) {}\n\ntry {\n  const todayAlerts = $node[\"Insertar Alertas Hoy\"];\n  if (todayAlerts && todayAlerts.json) {\n    todayCount = Array.isArray(todayAlerts.json) ? todayAlerts.json.length : 1;\n  }\n} catch (e) {}\n\nconst summary = {\n  date: new Date().toISOString().split('T')[0],\n  tomorrow_count: tomorrowCount,\n  today_count: todayCount,\n  total_alerts: tomorrowCount + todayCount\n};\n\nreturn [{ json: summary }];\n"

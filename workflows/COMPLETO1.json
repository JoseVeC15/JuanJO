        "functionCode": "// Validar datos de entrada y convertir a binario\nconst data = $input.first().json.body || {};\n\nif (!data.user_id || !data.image_base64) {\n  throw new Error('Faltan campos requeridos: user_id, image_base64');\n}\n\nreturn [{\n  binary: {\n    data: {\n      data: data.image_base64,\n      mimeType: 'image/jpeg',\n      fileName: `factura_${Date.now()}.jpg`\n    }\n  },\n  json: {\n    user_id: data.user_id,\n    timestamp: new Date().toISOString()\n  }\n}];"

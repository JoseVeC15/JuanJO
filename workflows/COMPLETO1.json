        "functionCode": "// Enviar notificaciones para equipos que vencen hoy\nconst data = $input.first().json;\nconst equipment = data.equipment;\n\nif (equipment.length === 0) {\n  return [{ json: { urgent_alerts: 0 } }];\n}\n\nconst urgentAlerts = [];\nfor (const item of equipment) {\n  urgentAlerts.push({\n    user_id: item.user_id,\n    tipo_alerta: 'renta_vence_hoy',\n    referencia_id: item.id,\n    fecha_ejecucion: new Date().toISOString().split('T')[0],\n    message: `🚨 HOY devuelve: ${item.nombre} a ${item.proveedor_renta}`\n  });\n}\n\nreturn urgentAlerts.map(alert => ({ json: alert }));"

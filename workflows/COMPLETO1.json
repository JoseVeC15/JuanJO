    {
      "parameters": {
        "authentication": "genericCredentialType",
        "url": "https://vision.googleapis.com/v1/images:annotate",
        "options": {}
      },
      "id": "9bed5593-035e-43a3-b614-cac3e0673743",
      "name": "Google Vision API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        -16,
        512
      ]
    },
    {
      "parameters": {
        "functionCode": "// Parsear respuesta de Google Vision\nconst response = $input.first().json;\nconst text = response.responses[0].fullTextAnnotation.text;\n\n// Funciones de extracción\nfunction extractAmount(text) {\n  // Buscar montos en formato MXN o USD\n  const patterns = [\n    /\\$\\s?([\\d,]+\\.\\d{2})/g,\n    /MXN\\s?([\\d,]+\\.\\d{2})/g,\n    /USD\\s?([\\d,]+\\.\\d{2})/g,\n    /TOTAL[:\\s]*([\\d,]+\\.\\d{2})/g,\n    /IMPORTE[:\\s]*([\\d,]+\\.\\d{2})/g\n  ];\n  \n  let amounts = [];\n  for (const pattern of patterns) {\n    let match;\n    while ((match = pattern.exec(text)) !== null) {\n      const amount = parseFloat(match[1].replace(/,/g, ''));\n      if (amount > 0 && amount < 1000000) {\n        amounts.push(amount);\n      }\n    }\n  }\n  \n  // Retornar el monto más común o el último encontrado\n  return amounts.length > 0 ? Math.max(...amounts) : null;\n}\n\nfunction extractDate(text) {\n  const patterns = [\n    /(\\d{1,2})[\\/\\-](\\d{1,2})[\\/\\-](\\d{2,4})/,\n    /(\\d{4})[\\/\\-](\\d{1,2})[\\/\\-](\\d{1,2})/,\n    /(\\d{1,2})\\s+(ene|feb|mar|abr|may|jun|jul|ago|sep|oct|nov|dic)[a-z]*\\s+(\\d{2,4})/i\n  ];\n  \n  for (const pattern of patterns) {\n    const match = text.match(pattern);\n    if (match) {\n      let date;\n      if (pattern.source.includes('ene|feb')) {\n        // Formato con meses en español\n        const months = {\n          'ene': 0, 'feb': 1, 'mar': 2, 'abr': 3, 'may': 4, 'jun': 5,\n          'jul': 6, 'ago': 7, 'sep': 8, 'oct': 9, 'nov': 10, 'dic': 11\n        };\n        const day = parseInt(match[1]);\n        const month = months[match[2].toLowerCase()];\n        const year = parseInt(match[3]);\n        date = new Date(year, month, day);\n      } else {\n        date = new Date(match[0]);\n      }\n      \n      if (!isNaN(date.getTime())) {\n        return date.toISOString().split('T')[0];\n      }\n    }\n  }\n  return null;\n}\n\nfunction extractProvider(text) {\n  const lines = text.split('\\n').filter(line => line.trim().length > 3);\n  // Las primeras líneas suelen ser el proveedor\n  for (let i = 0; i < Math.min(5, lines.length); i++) {\n    const line = lines[i].trim();\n    if (line.length > 3 && line.length < 100 && !line.match(/^\\d/)) {\n      return line;\n    }\n  }\n  return 'Proveedor no identificado';\n}\n\nconst extractedData = {\n  monto: extractAmount(text),\n  fecha_factura: extractDate(text),\n  proveedor: extractProvider(text),\n  concepto_ocr: text\n};\n\nreturn [{\n  json: {\n    ...$node[\"Preparar OCR\"].json,\n    ...extractedData\n  }\n}];"
      },

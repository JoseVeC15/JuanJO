    {
      "parameters": {
        "jsCode": "// Crear mensaje para Telegram\nconst data = $input.all();\n\nif (data.length === 0) {\n  return [{ json: { has_overdue: false, count: 0 } }];\n}\n\nconst payments = data.map(item => item.json);\nconst totalAmount = payments.reduce((sum, p) => sum + parseFloat(p.monto), 0);\nconst formatCurrency = (amount) => {\n  return new Intl.NumberFormat('es-MX', {\n    style: 'currency',\n    currency: 'MXN'\n  }).format(amount);\n};\n\nlet message = `📊 **Reporte de Pagos Pendientes**\\n\\n`;\nmessage += `⏰ Clientes con pagos >30 dias:\\n\\n`;\n\n// Top 5 por monto\nconst topPayments = payments.slice(0, 5);\ntopPayments.forEach((p, i) => {\n  message += `${i + 1}. **${p.cliente}** - ${formatCurrency(p.monto)}\\n`;\n});\n\nmessage += `\\n💰 **Total pendiente:** ${formatCurrency(totalAmount)}`;\nmessage += `\\n📋 **Total facturas:** ${payments.length}`;\n\nreturn [{\n  json: {\n    telegram_message: message,\n    summary: {\n      count: payments.length,\n      total: totalAmount\n    }\n  }\n}];"
      },

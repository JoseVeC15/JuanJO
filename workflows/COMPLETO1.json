    {
      "parameters": {
        "functionCode": "// Parsear respuesta de OpenAI\nconst response = $input.first().json.text;\nlet extracted = {};\n\nif (response.includes('TRANSFERENCIA')) {\n  extracted = { monto: 0, proveedor: 'TRANSFERENCIA', concepto_ocr: 'Comprobante de Pago' };\n} else {\n  try {\n    const jsonMatch = response.match(/\\{.*\\}/s);\n    extracted = JSON.parse(jsonMatch ? jsonMatch[0] : response);\n  } catch (e) {}\n}\n\nreturn [{\n  json: {\n    ...$node[\"Preparar OCR\"].json,\n    monto: extracted.monto || 0,\n    fecha_factura: extracted.fecha_factura || new Date().toISOString().split('T')[0],\n    proveedor: extracted.proveedor || 'Proveedor desconocido',\n    concepto_ocr: extracted.concepto_ocr || response.substring(0, 500)\n  }\n}];"
      },

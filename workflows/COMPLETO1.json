    {
      "parameters": {
        "jsCode": "const data = $input.all();\nconst clean = (text) => text ? String(text).replace(/[_*`]/g, ' ') : '';\nconst formatCurrency = (amount) => new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(amount);\n\nlet message = `📊 **Reporte de Pagos Pendientes**\\n\\n`;\nconst payments = data.map(item => item.json);\n\npayments.slice(0, 5).forEach((p, i) => {\n  message += `${i + 1}. **${clean(p.cliente)}** - ${formatCurrency(p.monto)}\\n`;\n});\n\nreturn [{ json: { telegram_message: message } }];"
      },
